{
  "name": "property-search",
  "version": "1.0.0",
  "description": "CLI tool for searching apartments via Realtor.com API with Google Maps distance filtering and buy-vs-stocks financial evaluation",
  "type": "module",
  "scripts": {
    "search": "tsx src/search-with-distance.ts",
    "search:sold": "tsx src/search-with-distance.ts --sold",
    "search:rent": "tsx src/search-with-distance.ts --rent",
    "search:rent-sold": "tsx src/search-with-distance.ts --rent-sold",
    "evaluate": "tsx src/evaluate.ts"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
